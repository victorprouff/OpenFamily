# OpenFamily production environment example
# Copy to .env on your production host and update every value.

# Database (Docker Compose internal network)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openfamily
POSTGRES_USER=openfamily
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Server
SERVER_PORT=3001
NODE_ENV=production
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Public URLs
VITE_API_URL=https://api.your-domain.tld
VITE_WS_URL=wss://api.your-domain.tld
CORS_ORIGINS=https://app.your-domain.tld

# Optional push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.tld
